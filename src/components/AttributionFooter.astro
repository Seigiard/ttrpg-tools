---
interface Props {
  /** Имя автора оригинала. */
  author: string;
  /** Название исходной системы или работы. */
  source: string;
  /** Ссылка на источник. */
  sourceUrl: string;
  /** Текст условий лицензии (короткий). */
  license: string;
  /** Ссылка на полный текст лицензии. */
  licenseUrl: string;
}

const { author, source, sourceUrl, license, licenseUrl } = Astro.props;
---

<footer class="mt-16 border-t border-border pt-6 pb-12 text-sm text-text-muted">
  <p>
    Основано на <a href={sourceUrl} class="underline hover:text-primary">{source}</a>
    {author}. Распространяется на условиях
    <a href={licenseUrl} class="underline hover:text-primary">{license}</a>.
  </p>
  <p class="mt-1">Перевод и интерфейс — TTRPG Tools.</p>
</footer>
