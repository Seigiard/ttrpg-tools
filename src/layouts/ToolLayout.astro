---
import Layout from './Layout.astro';

interface Props {
  /** Заголовок инструмента — попадает в <title> и шапку. */
  title: string;
  /** Короткое описание под заголовком. */
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={`${title} · TTRPG Tools`}>
  <header class="border-b border-border">
    <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
      <a href="/" class="font-mono text-xs uppercase tracking-wider text-text-muted hover:text-primary">
        ← TTRPG Tools
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-4xl text-text">{title}</h1>
      {description ? <p class="mt-2 text-text-muted">{description}</p> : null}
    </div>

    <slot />
  </main>

  <div class="mx-auto max-w-3xl px-6">
    <slot name="footer" />
  </div>
</Layout>
