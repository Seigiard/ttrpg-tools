---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AttributionFooter from '@/components/AttributionFooter.astro';
import { WeatherGenerator } from '@/components/WeatherGenerator';
import { mausritterWeather } from '@/data/mausritter/weather';
---

<ToolLayout
  title="Погода Mausritter"
  description="Генератор погоды по сезонам для путешествий в Mausritter."
>
  <section class="mb-10 text-text-muted">
    <p>
      Проходи проверку погоды каждый день — выбери сезон, нажми «Бросить погоду» (2d6) и сверься с
      таблицей. Под результатом — вся таблица по сезонам, если предпочитаете кидать реальные кубики.
    </p>
    <p class="mt-3">
      Погода, выделенная <span class="font-semibold text-text">жирным</span>, не слишком подходит
      для путешествия. За каждую вахту, которую персонажи в пути с такими условиями, каждая мышь
      должна пройти спасбросок силы или получить карточку состояния «Изнурён».
    </p>
  </section>

  <WeatherGenerator client:load table={mausritterWeather} />

  <AttributionFooter
    slot="footer"
    author="Айзека Уильямса"
    source="Mausritter"
    sourceUrl="https://losing.games/mausritter/"
    license="Mausritter Third Party License"
    licenseUrl="https://losing.games/mausritter/"
  />
</ToolLayout>
