---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AttributionFooter from '@/components/AttributionFooter.astro';
import { LocationGenerator } from '@/components/LocationGenerator';
import { mausritterLocations } from '@/data/mausritter/locations';
---

<ToolLayout
  title="Локации Mausritter"
  description="Генератор деталей гекса для гекскраулов в Mausritter."
>
  <section class="mb-10 text-text-muted">
    <p>
      Гекскраулы в Mausritter идут в масштабе 1 миля на гекс. В каждом гексе должен быть один
      заметный ориентир с интересной деталью. Этот генератор быстро заполняет такие гексы.
    </p>
    <p class="mt-3">
      Выберите биом, нажмите «Бросить локацию» — получите Ориентир (d20 по выбранному биому) и
      Деталь (d20 из общей таблицы). Любую часть можно перебросить отдельно. Под результатом — сами
      таблицы, если предпочитаете кидать реальные кубики.
    </p>
  </section>

  <LocationGenerator client:load table={mausritterLocations} />

  <AttributionFooter
    slot="footer"
    author="Айзека Уильямса"
    source="Mausritter"
    sourceUrl="https://losing.games/mausritter/"
    license="Mausritter Third Party License"
    licenseUrl="https://losing.games/mausritter/"
  />
</ToolLayout>
